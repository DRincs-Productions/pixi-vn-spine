{
  "name": "@drincs/pixi-vn-spine",
  "description": "Spine 2D integration for Pixi'VN",
  "version": "0.2.1",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup --config tsup.config.ts",
    "lint": "biome lint",
    "check": "biome check",
    "format": "biome format --write",
    "test": "vitest"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.mjs"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js",
      "require": "./dist/core.js",
      "default": "./dist/core.js"
    }
  },
  "typesVersions": {
    "*": {
      "core": [
        "./dist/core.d.ts"
      ]
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DRincs-Productions/pixi-vn-spine.git"
  },
  "author": "DRincs-Productions",
  "license": "LGPL-2.1",
  "bugs": {
    "url": "https://github.com/DRincs-Productions/pixi-vn-spine/issues"
  },
  "homepage": "https://pixi-vn.web.app/start/canvas-spine2d",
  "funding": "https://github.com/DRincs-Productions/pixi-vn?sponsor=1",
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "jsdom": "^29.0.2",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vite-tsconfig-paths": "^6.1.1"
  },
  "dependencies": {
    "@esotericsoftware/spine-core": "^4.2.0",
    "@esotericsoftware/spine-pixi-v8": "^4.2.0",
    "vitest": "^4.1.4"
  },
  "peerDependencies": {
    "@drincs/pixi-vn": ">=1.5.13",
    "@esotericsoftware/spine-core": "^4.2.0",
    "@esotericsoftware/spine-pixi-v8": "^4.2.0"
  },
  "keywords": [
    "pixi-vn",
    "spine-2D",
    "spine",
    "2D"
  ]
}
