{
  "name": "@drincs/pixi-vn-spine",
  "description": "Spine 2D integration for Pixi'VN",
  "version": "0.3.1",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "workspaces": [
    "playground"
  ],
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup --config tsup.config.ts",
    "lint": "biome lint",
    "check": "biome check",
    "format": "biome format --write",
    "test": "vitest",
    "docs": "typedoc",
    "playground": "npm run build && npm run dev --workspace=playground",
    "generate-spine-options-schema": "node scripts/generate-spine-options-schema.mjs && biome format --write src/ink/spine-options-schema.generated.ts"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.mjs"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js",
      "require": "./dist/core.js",
      "default": "./dist/core.js"
    },
    "./ink": {
      "types": "./dist/ink.d.ts",
      "import": "./dist/ink.mjs",
      "require": "./dist/ink.cjs",
      "default": "./dist/ink.mjs"
    }
  },
  "typesVersions": {
    "*": {
      "core": [
        "./dist/core.d.ts"
      ],
      "ink": [
        "./dist/ink.d.ts"
      ]
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DRincs-Productions/pixi-vn-spine.git"
  },
  "author": "DRincs-Productions",
  "license": "LGPL-2.1",
  "bugs": {
    "url": "https://github.com/DRincs-Productions/pixi-vn-spine/issues"
  },
  "homepage": "https://pixi-vn.web.app/start/canvas-spine2d",
  "funding": "https://github.com/DRincs-Productions/pixi-vn?sponsor=1",
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@drincs/pixi-vn-ink": "^1.1.6",
    "@drincs/pixi-vn-json": "^1.13.16",
    "jsdom": "^29.0.2",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.12.0",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^6.1.1",
    "zod": "^4.4.3"
  },
  "dependencies": {
    "vitest": "^4.1.4"
  },
  "peerDependencies": {
    "@drincs/pixi-vn": ">=1.5.13",
    "@drincs/pixi-vn-ink": ">=1.1.6",
    "@esotericsoftware/spine-core": "^4.3.9",
    "@esotericsoftware/spine-pixi-v8": "^4.3.9",
    "zod": ">=4.4.0"
  },
  "peerDependenciesMeta": {
    "@drincs/pixi-vn-ink": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  },
  "keywords": [
    "pixi-vn",
    "spine-2D",
    "spine",
    "2D"
  ]
}
